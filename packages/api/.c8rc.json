{
  "all": true,
  "cache": false,
  "extension": [
    ".js"
  ],
  "include": [
    "tests/compiled/**/src/**"
  ],
  "exclude": [
    "tests/compiled/**/src/index.js",
    "tests/compiled/**/src/types.js",
    "tests/compiled/**/src/types/**"
  ],
  "reporter": [
    "text",
    "lcov",
    "cobertura",
    "json-summary"
  ],
  "omit-relative": true,
  "cwd": "./",
  "report-dir": "./coverage"
}
