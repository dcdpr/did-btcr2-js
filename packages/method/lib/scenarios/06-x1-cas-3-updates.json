{
  "id": "06-x1-cas-3-updates",
  "description": "x1 DID with default 3 singleton beacons, 3 updates delivered via CAS (didcomm, dwn, then deactivate). Mirrors danubetech example 6. CAS publishing + on-chain anchoring pending (Batch C).",
  "network": "mutinynet",
  "idType": "EXTERNAL",
  "keys": { "source": "fixed", "secretHex": "5fded3732c408b6fbb1ad321a544bfb27ba7d1eb710af0c508ac6c54886ab7b3" },
  "delivery": { "genesis": "cas" },
  "beacons": [
    { "kind": "P2PKH", "id": "#initialP2PKH" },
    { "kind": "P2WPKH", "id": "#initialP2WPKH" },
    { "kind": "P2TR", "id": "#initialP2TR" }
  ],
  "updates": [
    {
      "patches": [
        {
          "op": "add",
          "path": "/service/3",
          "value": {
            "id": "#didcomm",
            "type": "DIDCommMessaging",
            "serviceEndpoint": "http://example.com/didcomm"
          }
        }
      ],
      "verificationMethodId": "#initialKey",
      "beaconId": "#initialP2WPKH",
      "delivery": "cas"
    },
    {
      "patches": [
        {
          "op": "add",
          "path": "/service/4",
          "value": {
            "id": "#dwn",
            "type": "DecentralizedWebNode",
            "serviceEndpoint": "http://example.com/dwn"
          }
        }
      ],
      "verificationMethodId": "#initialKey",
      "beaconId": "#initialP2WPKH",
      "delivery": "cas"
    },
    {
      "patches": [
        { "op": "add", "path": "/deactivated", "value": true }
      ],
      "verificationMethodId": "#initialKey",
      "beaconId": "#initialP2WPKH",
      "delivery": "cas"
    }
  ]
}
