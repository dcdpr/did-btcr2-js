{
    "name": "@did-btcr2/method",
    "version": "0.51.0",
    "type": "module",
    "description": "Reference implementation for the did:btcr2 DID method written in TypeScript and JavaScript. did:btcr2 is a censorship resistant DID Method using the Bitcoin blockchain as a Verifiable Data Registry to announce changes to the DID document. This is the core method implementation for the did-btcr2-js monorepo.",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "browser": "./dist/browser.mjs",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        },
        "./browser": {
            "type": "./dist/types/index.d.ts",
            "default": "./dist/browser.mjs"
        }
    },
    "typesVersions": {
        "*": {
            "browser": [
                "dist/types/index.d.ts"
            ]
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "license": "MPL-2.0",
    "contributors": [
        {
            "name": "dcdpr",
            "url": "https://github.com/dcdpr"
        },
        {
            "name": "jintekc",
            "url": "https://github.com/jintekc",
            "email": "github@jintek.consulting"
        }
    ],
    "homepage": "https://github.com/dcdpr/did-btcr2-js/tree/main/packages/method",
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com:dcdpr/did-btcr2-js.git",
        "directory": "packages/method"
    },
    "bugs": "https://github.com/dcdpr/did-btcr2-js/issues",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "keywords": [
        "did",
        "dids",
        "decentralized identity",
        "decentralized identifiers",
        "did method",
        "did:btcr2",
        "bitcoin"
    ],
    "scripts": {
        "clean": "rimraf dist coverage tests/compiled",
        "clean:build": "rimraf dist",
        "clean:tests": "rimraf coverage tests/compiled",
        "wipe": "rimraf node_modules pnpm-lock.json",
        "wipe:clean": "pnpm wipe && pnpm clean",
        "wipe:install": "pnpm wipe && pnpm install",
        "clean:install": "pnpm clean && pnpm install",
        "wipe:clean:install": "pnpm wipe:clean && pnpm install",
        "reinstall": "pnpm install --force",
        "build": "pnpm clean:build && pnpm build:esm && pnpm build:cjs && pnpm build:browser",
        "build:esm": "rimraf dist/esm dist/types && pnpm tsc -p tsconfig.json",
        "build:cjs": "tsup && echo '{\"type\": \"commonjs\"}' > ./dist/cjs/package.json",
        "build:browser": "rimraf dist/browser.mjs dist/browser.js && node build/bundles.js",
        "build:tests": "pnpm clean:tests && pnpm tsc -p tests/tsconfig.json",
        "build:docs": "typedoc --options typedoc.json",
        "build:all": "pnpm build && pnpm build:tests",
        "release": "pnpm build && pnpm pack && mv *.tgz ../../release/method",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --fix",
        "test": "pnpm c8 mocha",
        "test:unit": "[ -z \"$FILE_NAME\" ] && echo 'ERROR: FILE_NAME is not set' || bun lib/test-$FILE_NAME.ts",
        "build:test": "pnpm build && pnpm build:tests && pnpm c8 mocha",
        "build:lint:test": "pnpm build && pnpm build:tests && pnpm lint:fix",
        "prepublish": "pnpm build",
        "generate:vector": "bun lib/generate-vector.ts",
        "generate:scenario": "bun lib/generate-scenario.ts",
        "scenario:keys": "bun lib/scenario-keys.ts",
        "scenario:artifacts": "bun lib/build-artifacts.ts",
        "scenario:route": "bun lib/route-delivery.ts",
        "scenario:publish": "bun lib/publish-scenarios.ts",
        "scenario:funding": "bun lib/aggregate-funding.ts",
        "scenario:fund": "bun lib/fund-scenarios.ts",
        "scenario:anchor": "bun lib/anchor-scenarios.ts",
        "scenario:verify": "bun lib/verify-scenarios.ts",
        "scenario:verify:live": "bun lib/verify-live.ts",
        "wallet": "bun lib/wallet/cli.ts",
        "do": "bun",
        "do:lib": "${PWD}/lib/run-lib.sh",
        "pack:local": "pnpm pack && mv *.tgz ./release"
    },
    "dependencies": {
        "@did-btcr2/bitcoin": "workspace:^",
        "@did-btcr2/common": "workspace:^",
        "@did-btcr2/cryptosuite": "workspace:^",
        "@did-btcr2/keypair": "workspace:^",
        "@did-btcr2/smt": "workspace:^",
        "@noble/curves": "^1.9.7",
        "@noble/hashes": "^1.8.0",
        "@scure/base": "^1.2.6",
        "@scure/btc-signer": "^1.8.1",
        "@web5/dids": "^1.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/chai": "^5.2.3",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "c8": "^10.1.3",
        "chai": "^5.3.3",
        "commander": "^13.1.0",
        "esbuild": "^0.24.2",
        "eslint": "^9.39.4",
        "eslint-plugin-mocha": "^10.5.0",
        "globals": "^15.15.0",
        "mocha": "^10.8.2",
        "multiformats": "^13.4.2",
        "node-stdlib-browser": "^1.3.1",
        "rimraf": "^6.1.3",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    }
}
