{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "moduleDetection": "auto",
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "composite": false
  }
}
